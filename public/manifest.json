{
  "name": "SmartCity Lab (SCL) Student Portal",
  "short_name": "SCL Portal", 
  "description": "Location-based attendance and student management system for SmartCity Lab",
  "version": "1.0.0",
  "start_url": "/pwa/login",
  "display": "standalone",
  "background_color": "#0f172a",
  "theme_color": "#3b82f6",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "icons": [
    {
      "src": "https://i.ibb.co/YBfg1BR8/1000264552-removebg-preview-1.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "https://i.ibb.co/YBfg1BR8/1000264552-removebg-preview-1.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "https://i.ibb.co/YBfg1BR8/1000264552-removebg-preview-1.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Mark Attendance",
      "short_name": "Attendance",
      "description": "Quickly mark your attendance",
      "url": "/pwa/attendance"
    },
    {
      "name": "View Profile", 
      "short_name": "Profile",
      "description": "View your student profile",
      "url": "/pwa/profile"
    }
  ],
  "categories": ["education", "productivity", "utilities"],
  "prefer_related_applications": false,
  "protocol_handlers": [
    {
      "protocol": "web+scl",
      "url": "/pwa?action=%s"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  }
}